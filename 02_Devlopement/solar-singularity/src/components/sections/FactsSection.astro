---
import FactCard from '../FactCard.astro';
---

<section
  id="facts"
  class="relative z-10 py-32 md:py-48"
  aria-labelledby="facts-heading"
>
  <div class="w-full px-6 md:px-12 lg:px-20">
    <div class="max-w-6xl mx-auto">

      <!-- Section Header -->
      <header class="text-center mb-20 md:mb-32">
        <span class="inline-block px-4 py-1.5 bg-cyan-accent/10 border border-cyan-accent/30 rounded-full text-xs font-mono font-bold uppercase tracking-widest text-cyan-accent mb-4">
          Geschichte & Rekorde / History & Records
        </span>
        <h2
          id="facts-heading"
          class="text-4xl md:text-5xl lg:text-6xl font-black uppercase tracking-tighter text-white"
        >
          Padel in <span class="text-electric-lime">Zahlen</span>
        </h2>
        <p class="text-slate-400 mt-4 max-w-xl mx-auto">
          Von den Anfängen in Mexiko bis zu den Rekorden der Padel-Welt – die Fakten, die den Sport prägen.
        </p>
      </header>

      <!-- Facts Timeline -->
      <div class="relative space-y-24 md:space-y-32">
        <!-- Vertical line (desktop only) -->
        <div class="hidden md:block absolute left-1/2 top-0 bottom-0 w-px bg-gradient-to-b from-transparent via-white/20 to-transparent -translate-x-1/2" aria-hidden="true"></div>

        <!-- Fact 1: Enrique Corcuera -->
        <div class="relative">
          <div class="grid grid-cols-1 md:grid-cols-2 gap-8 md:gap-16 items-center">
            <FactCard
              year="1969"
              label="Meilenstein / Milestone"
              headline="Enrique Corcuera erfindet Padel"
              description="In Acapulco, Mexiko, baute Enrique Corcuera die erste Padel-Anlage. Er kombinierte Tennis mit Squash-Elementen: ein kleinerer Court (20×10 m), Glas- und Gitterwände sowie der charakteristische Unterhand-Aufschlag. Die Grundlage für den am schnellsten wachsenden Racketsport der Welt."
              accentColor="lime"
              align="left"
              ariaLabel="Historischer Meilenstein: Enrique Corcuera erfindet Padel 1969 in Acapulco"
            />
            <div class="hidden md:flex justify-center">
              <div class="w-4 h-4 bg-electric-lime rounded-full shadow-[0_0_20px_rgba(206,255,5,0.5)] ring-4 ring-deep-blue/50"></div>
            </div>
          </div>
        </div>

        <!-- Fact 2: Wand-Element -->
        <div class="relative">
          <div class="grid grid-cols-1 md:grid-cols-2 gap-8 md:gap-16 items-center">
            <div class="hidden md:flex justify-center order-1">
              <div class="w-4 h-4 bg-cyan-accent rounded-full shadow-[0_0_20px_rgba(0,212,255,0.5)] ring-4 ring-deep-blue/50"></div>
            </div>
            <div class="order-2 md:order-2">
              <FactCard
                year="1990er"
                label="Innovation / Innovation"
                headline="Glaswände revolutionieren das Spiel"
                description="Die Einführung von transparenten Glaswänden an den Grundlinien und Gitterwänden an den Seiten machte Padel zum Zuschauersport schlechthin. Das Spiel wird dynamischer, strategischer und visuell spektakulärer – ein einzigartiges Erlebnis für Spieler und Publikum gleichermaßen."
                accentColor="cyan"
                align="right"
                ariaLabel="Innovation: Glaswände revolutionieren das Padel-Spiel in den 1990er Jahren"
              />
            </div>
          </div>
        </div>

        <!-- Fact 3: Belasteguín -->
        <div class="relative">
          <div class="grid grid-cols-1 md:grid-cols-2 gap-8 md:gap-16 items-center">
            <FactCard
              year="2016"
              label="Rekord / Record"
              headline="Belasteguín – 16 Jahre an der Spitze"
              description="Der Argentinier Fernando Belasteguín dominierte die Padel-Weltrangliste unglaubliche 16 Jahre lang (2002–2017) – ein Rekord, der in keinem anderen Racketsport je erreicht wurde. Seine Kombination aus Präzision, Taktik und mentaler Stärke machte ihn zur lebenden Legende des Sports."
              accentColor="orange"
              align="left"
              ariaLabel="Rekord: Fernando Belasteguín 16 Jahre an der Spitze der Padel-Weltrangliste"
            />
            <div class="hidden md:flex justify-center">
              <div class="w-4 h-4 bg-orange-400 rounded-full shadow-[0_0_20px_rgba(251,146,60,0.5)] ring-4 ring-deep-blue/50"></div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
