---
import QuoteBlock from '../QuoteBlock.astro';
import BookingWidget from '../BookingWidget.astro';
---

<section
  class="relative z-10 py-32 md:py-48"
  aria-labelledby="quote-section"
>
  <div class="w-full px-6 md:px-12 lg:px-20">
    <div class="max-w-5xl mx-auto">
      <!-- Decorative elements -->
      <div class="absolute left-1/4 top-1/2 -translate-y-1/2 w-64 h-64 bg-electric-lime/5 rounded-full blur-3xl pointer-events-none" aria-hidden="true"></div>
      <div class="absolute right-1/4 top-1/2 -translate-y-1/2 w-64 h-64 bg-cyan-accent/5 rounded-full blur-3xl pointer-events-none" aria-hidden="true"></div>

      <QuoteBlock
        quote="Padel is played with the heart. The racket is just the tool. Every point is a new opportunity to connect with your partner and push beyond your limits."
        author="Fernando Belasteguín"
        class="relative"
      />

      <!-- Prominent CTA -->
      <div class="mt-16 text-center flex flex-col items-center gap-4">
        <BookingWidget variant="hero" />
        <a
          href="#contact"
          class="inline-flex items-center gap-2 px-8 py-4 bg-white/5 border border-white/20 text-white font-bold text-sm uppercase tracking-wider rounded-lg hover:bg-white/10 hover:border-white/40 transition-all duration-300 focus:outline-none focus:ring-2 focus:ring-electric-lime focus:ring-offset-2 focus:ring-offset-deep-blue"
        >
          Oder schreib uns / Or contact us
        </a>
      </div>
    </div>
  </div>
</section>
