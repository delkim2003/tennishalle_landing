---
---

<section
  id="contact"
  class="relative z-10 py-24 md:py-32"
  aria-labelledby="contact-heading"
>
  <div class="w-full px-6 md:px-12 lg:px-20">
    <div class="max-w-6xl mx-auto">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-20">
        
        <!-- Info -->
        <div>
          <span class="inline-block px-4 py-1.5 bg-cyan-accent/10 border border-cyan-accent/30 rounded-full text-xs font-mono font-bold uppercase tracking-widest text-cyan-accent mb-6">
            Kontakt / Contact
          </span>
          
          <h2
            id="contact-heading"
            class="text-4xl md:text-5xl font-black uppercase tracking-tighter text-white mb-6"
          >
            Schreib uns <span class="text-electric-lime">eine Nachricht</span>
          </h2>
          
          <p class="text-lg text-slate-300 mb-8 leading-relaxed">
            Du hast Fragen zur Buchung, möchtest eine Schulkooperation besprechen oder Sponsoring-Details erfahren?
            Wir melden uns so schnell wie möglich bei dir.
          </p>
          
          <div class="space-y-6">
            <div class="flex items-start gap-4">
              <div class="w-12 h-12 bg-electric-lime/10 border border-electric-lime/20 rounded-xl flex items-center justify-center flex-shrink-0">
                <svg class="w-6 h-6 text-electric-lime" viewBox="0 0 256 256" fill="currentColor" aria-hidden="true">
                  <path d="M224 48H32a16 16 0 0 0-16 16v128a16 16 0 0 0 16 16h192a16 16 0 0 0 16-16V64a16 16 0 0 0-16-16Zm0 32-80 53.33L32 80V64l96 64 96-64v16Z"/>
                </svg>
              </div>
              <div>
                <div class="text-white font-bold">E-Mail</div>
                <div class="text-slate-400">info@alfa-padel.at</div>
              </div>
            </div>
            
            <div class="flex items-start gap-4">
              <div class="w-12 h-12 bg-cyan-accent/10 border border-cyan-accent/20 rounded-xl flex items-center justify-center flex-shrink-0">
                <svg class="w-6 h-6 text-cyan-accent" viewBox="0 0 256 256" fill="currentColor" aria-hidden="true">
                  <path d="M222.37 158.46l-47.11-21.11-.13-.06a16 16 0 0 0-15.17 1.4 8.12 8.12 0 0 0-.75.56L134.87 160c-15.42-7.49-31.34-23.29-38.83-38.51l20.78-24.71c.2-.25.39-.5.57-.77a16 16 0 0 0 1.32-15.06v-.12L97.54 33.64a16 16 0 0 0-16.62-9.52A56.26 56.26 0 0 0 32 80c0 79.4 64.6 144 144 144a56.26 56.26 0 0 0 55.88-48.92 16 16 0 0 0-9.51-16.62Z"/>
                </svg>
              </div>
              <div>
                <div class="text-white font-bold">Telefon</div>
                <div class="text-slate-400">+43 123 456 789</div>
              </div>
            </div>
            
            <div class="flex items-start gap-4">
              <div class="w-12 h-12 bg-orange-400/10 border border-orange-400/20 rounded-xl flex items-center justify-center flex-shrink-0">
                <svg class="w-6 h-6 text-orange-400" viewBox="0 0 256 256" fill="currentColor" aria-hidden="true">
                  <path d="M128 16a88.1 88.1 0 0 0-88 88c0 75.3 80 132.17 83.41 134.55a8 8 0 0 0 9.18 0C136 236.17 216 179.3 216 104a88.1 88.1 0 0 0-88-88Zm0 120a32 32 0 1 1 32-32 32 32 0 0 1-32 32Z"/>
                </svg>
              </div>
              <div>
                <div class="text-white font-bold">Adresse</div>
                <div class="text-slate-400">Gewerbegebiet Burgau<br/>8291 Burgau, Österreich</div>
              </div>
            </div>
          </div>
        </div>
        
        <!-- Demo Form -->
        <div
          class="p-8 md:p-10 bg-white/10 backdrop-blur-xl border border-white/20 rounded-2xl shadow-2xl"
          x-data="{ name: '', email: '', phone: '', subject: '', message: '', privacy: false, _gotcha: '', submitted: false, loading: false, serverError: '', errors: {}, validate() { this.errors = {}; if (!this.name.trim()) this.errors.name = 'Name ist erforderlich / Name is required'; if (!this.email.trim() || !/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(this.email)) this.errors.email = 'Gültige E-Mail erforderlich / Valid email required'; if (!this.subject) this.errors.subject = 'Betreff auswählen / Please select a subject'; if (!this.message.trim()) this.errors.message = 'Nachricht ist erforderlich / Message is required'; if (!this.privacy) this.errors.privacy = 'Datenschutz zustimmen / Please accept privacy policy'; return Object.keys(this.errors).length === 0; }, async submit() { this.serverError = ''; if (!this.validate()) return; this.loading = true; try { const res = await fetch('/api/contact', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ name: this.name, email: this.email, phone: this.phone, subject: this.subject, message: this.message, privacy: this.privacy, _gotcha: '' }) }); const data = await res.json(); if (res.ok && data.success) { this.submitted = true; } else { this.serverError = data.error || 'Fehler beim Senden. / Error sending message.'; } } catch (e) { this.serverError = 'Netzwerkfehler. Bitte später erneut versuchen. / Network error. Please try again later.'; } finally { this.loading = false; } } }"
        >
          <div x-show="!submitted" x-transition.opacity.duration.300ms>
            <form @submit.prevent="submit()" class="space-y-5" novalidate>
              <!-- Honeypot – unsichtbar für Menschen -->
              <div class="hidden" aria-hidden="true">
                <input type="text" x-model="_gotcha" tabindex="-1" autocomplete="off" />
              </div>

              <div>
                <label for="contact-name" class="block text-sm font-medium text-slate-300 mb-1">
                  Name <span class="text-electric-lime">*</span>
                </label>
                <input
                  type="text"
                  id="contact-name"
                  x-model="name"
                  class="w-full px-4 py-3 bg-white/5 border border-white/20 rounded-lg text-white placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-electric-lime/60 focus:border-transparent transition-all"
                  placeholder="Max Mustermann"
                  :class="errors.name ? 'border-red-400 focus:ring-red-400/60' : ''"
                  :disabled="loading"
                />
                <p x-show="errors.name" x-text="errors.name" class="mt-1 text-xs text-red-400" x-cloak></p>
              </div>

              <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
                <div>
                  <label for="contact-email" class="block text-sm font-medium text-slate-300 mb-1">
                    E-Mail <span class="text-electric-lime">*</span>
                  </label>
                  <input
                    type="email"
                    id="contact-email"
                    x-model="email"
                    class="w-full px-4 py-3 bg-white/5 border border-white/20 rounded-lg text-white placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-electric-lime/60 focus:border-transparent transition-all"
                    placeholder="max@beispiel.at"
                    :class="errors.email ? 'border-red-400 focus:ring-red-400/60' : ''"
                    :disabled="loading"
                  />
                  <p x-show="errors.email" x-text="errors.email" class="mt-1 text-xs text-red-400" x-cloak></p>
                </div>
                <div>
                  <label for="contact-phone" class="block text-sm font-medium text-slate-300 mb-1">
                    Telefon <span class="text-slate-500">/ Phone (optional)</span>
                  </label>
                  <input
                    type="tel"
                    id="contact-phone"
                    x-model="phone"
                    class="w-full px-4 py-3 bg-white/5 border border-white/20 rounded-lg text-white placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-electric-lime/60 focus:border-transparent transition-all"
                    placeholder="+43 ..."
                    :disabled="loading"
                  />
                </div>
              </div>

              <div>
                <label for="contact-subject" class="block text-sm font-medium text-slate-300 mb-1">
                  Betreff <span class="text-electric-lime">*</span> / Subject
                </label>
                <select
                  id="contact-subject"
                  x-model="subject"
                  class="w-full px-4 py-3 bg-white/5 border border-white/20 rounded-lg text-white focus:outline-none focus:ring-2 focus:ring-electric-lime/60 focus:border-transparent transition-all appearance-none"
                  :class="errors.subject ? 'border-red-400 focus:ring-red-400/60' : ''"
                  :disabled="loading"
                >
                  <option value="" disabled selected>Betreff auswählen / Select subject</option>
                  <option value="general">Allgemeine Anfrage / General inquiry</option>
                  <option value="booking">Buchungsanfrage / Booking inquiry</option>
                  <option value="sponsoring">Sponsoring</option>
                  <option value="school">Schulkooperation / School partnership</option>
                  <option value="event">Event & Turniere / Events & tournaments</option>
                </select>
                <p x-show="errors.subject" x-text="errors.subject" class="mt-1 text-xs text-red-400" x-cloak></p>
              </div>

              <div>
                <label for="contact-message" class="block text-sm font-medium text-slate-300 mb-1">
                  Nachricht <span class="text-electric-lime">*</span> / Message
                </label>
                <textarea
                  id="contact-message"
                  x-model="message"
                  rows="4"
                  class="w-full px-4 py-3 bg-white/5 border border-white/20 rounded-lg text-white placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-electric-lime/60 focus:border-transparent transition-all resize-none"
                  placeholder="Deine Nachricht... / Your message..."
                  :class="errors.message ? 'border-red-400 focus:ring-red-400/60' : ''"
                  :disabled="loading"
                ></textarea>
                <p x-show="errors.message" x-text="errors.message" class="mt-1 text-xs text-red-400" x-cloak></p>
              </div>

              <div class="flex items-start gap-3">
                <input
                  type="checkbox"
                  id="contact-privacy"
                  x-model="privacy"
                  class="w-5 h-5 mt-0.5 bg-white/5 border border-white/20 rounded focus:ring-2 focus:ring-electric-lime/60 text-electric-lime cursor-pointer"
                  :class="errors.privacy ? 'border-red-400' : ''"
                  :disabled="loading"
                />
                <label for="contact-privacy" class="text-sm text-slate-400 cursor-pointer">
                  Ich stimme der Verarbeitung meiner Daten gemäß der DSGVO zu. /
                  I agree to the processing of my data in accordance with GDPR.
                </label>
              </div>
              <p x-show="errors.privacy" x-text="errors.privacy" class="text-xs text-red-400" x-cloak></p>

              <!-- Server-Fehler -->
              <p x-show="serverError" x-text="serverError" class="text-sm text-red-400 text-center" x-cloak></p>

              <button
                type="submit"
                class="w-full px-6 py-4 bg-electric-lime text-deep-blue font-bold text-sm uppercase tracking-wider rounded-lg hover:bg-white hover:shadow-[0_0_30px_rgba(206,255,5,0.3)] transition-all duration-300 focus:outline-none focus:ring-2 focus:ring-white focus:ring-offset-2 focus:ring-offset-deep-blue disabled:opacity-50 disabled:cursor-not-allowed"
                :disabled="loading"
              >
                <span x-show="!loading">Nachricht senden / Send Message</span>
                <span x-show="loading" class="inline-flex items-center gap-2">
                  <svg class="animate-spin h-4 w-4" viewBox="0 0 24 24" fill="none">
                    <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                    <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"></path>
                  </svg>
                  Wird gesendet... / Sending...
                </span>
              </button>
            </form>
          </div>

          <div x-show="submitted" x-transition.opacity.duration.300ms class="text-center py-12">
              <div class="w-20 h-20 bg-electric-lime/10 border border-electric-lime/30 rounded-full flex items-center justify-center mx-auto mb-6">
                <svg class="w-10 h-10 text-electric-lime" viewBox="0 0 256 256" fill="currentColor" aria-hidden="true">
                  <path d="m232.49 80.49-128 128a12 12 0 0 1-17 0l-56-56a12 12 0 1 1 17-17L96 183 215.51 63.51a12 12 0 0 1 17 17Z"/>
                </svg>
              </div>
              <h3 class="text-2xl font-bold text-white mb-3">Danke für deine Nachricht!</h3>
              <p class="text-slate-300 mb-2">Wir haben deine Anfrage erhalten.</p>
              <p class="text-slate-400 text-sm">We will get back to you as soon as possible.</p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>