---
import BookingWidget from '../BookingWidget.astro';
import { sponsors } from '../../data/sponsors';
const currentYear = new Date().getFullYear();
---

<!-- Pre-footer CTA -->
<div class="relative z-10 py-16 md:py-20 border-t border-white/10 bg-electric-lime/5">
  <div class="w-full px-6 md:px-12 lg:px-20">
    <div class="max-w-4xl mx-auto flex flex-col sm:flex-row items-center justify-between gap-6">
      <div>
        <h3 class="text-2xl md:text-3xl font-black uppercase tracking-tighter text-white">
          Noch Fragen? <span class="text-electric-lime">Wir helfen gerne.</span>
        </h3>
        <p class="text-slate-400 mt-1 text-sm">
          Buchung, Kooperation, Sponsoring – sprich uns an. / Booking, partnership, sponsoring – get in touch.
        </p>
      </div>
      <div class="flex flex-col sm:flex-row items-center gap-3">
        <BookingWidget variant="inline" />
        <a
          href="#contact"
          class="inline-flex items-center gap-2 px-6 py-4 bg-white/5 border border-white/20 text-white font-bold text-sm uppercase tracking-wider rounded-lg hover:bg-white/10 hover:border-white/40 transition-all duration-300 focus:outline-none focus:ring-2 focus:ring-electric-lime focus:ring-offset-2 focus:ring-offset-deep-blue"
        >
          Kontakt / Contact
        </a>
      </div>
    </div>
  </div>
</div>

<!-- Community Partner Network – Logo Cards -->
<div class="relative z-10 py-10 md:py-14 border-t border-white/10 bg-deep-blue/60 backdrop-blur-md">
  <div class="w-full px-6 md:px-12 lg:px-20">
    <div class="max-w-7xl mx-auto">
      <p class="text-center text-xs font-mono font-bold uppercase tracking-widest text-slate-500 mb-8">
        Community Partner Netzwerk / Community Partner Network
      </p>

      <div class="flex flex-wrap justify-center items-center gap-4 md:gap-6">
        {sponsors.map(sponsor => (
          <a
            href={sponsor.url}
            target={sponsor.url.startsWith('http') ? '_blank' : '_self'}
            rel={sponsor.url.startsWith('http') ? 'noopener noreferrer' : undefined}
            class="group flex flex-col items-center gap-3 px-5 py-4 bg-white/5 backdrop-blur-sm border border-white/10 rounded-xl hover:bg-white/10 hover:border-white/25 hover:-translate-y-1 transition-all duration-300 focus:outline-none focus:ring-2 focus:ring-electric-lime focus:ring-offset-2 focus:ring-offset-deep-blue"
            aria-label={sponsor.name}
          >
            <div class="w-[140px] h-[50px] flex items-center justify-center">
              {sponsor.logoPath ? (
                <img
                  src={sponsor.logoPath}
                  alt={sponsor.logoAlt}
                  width="140"
                  height="50"
                  loading="lazy"
                  decoding="async"
                  class="max-w-full max-h-full object-contain opacity-80 group-hover:opacity-100 grayscale group-hover:grayscale-0 transition-all duration-500"
                />
              ) : (
                <span class="text-sm font-black uppercase text-slate-400 group-hover:text-white transition-colors">{sponsor.name}</span>
              )}
            </div>
            <span class="text-xs text-slate-500 group-hover:text-slate-300 transition-colors font-medium">{sponsor.name}</span>
          </a>
        ))}
      </div>

      <!-- Sponsoring CTA -->
      <div class="mt-10 text-center">
        <a
          href="#contact"
          class="inline-flex items-center gap-2 text-xs text-slate-500 hover:text-electric-lime transition-colors duration-300 font-mono uppercase tracking-wider"
        >
          <svg class="w-3.5 h-3.5" viewBox="0 0 256 256" fill="currentColor" aria-hidden="true"><path d="M128 24a104 104 0 0 0-36.72 200.72 8 8 0 0 0 5.7-14.94 88 88 0 1 1 62.08 0 8 8 0 0 0 5.7 14.94A104.11 104.11 0 0 0 128 24Z"/></svg>
          Partner werden? / Become a partner?
          <svg class="w-3.5 h-3.5" viewBox="0 0 256 256" fill="currentColor" aria-hidden="true"><path d="M128 24a104 104 0 1 0 104 104A104.11 104.11 0 0 0 128 24Zm45.66 109.66-32 32a8 8 0 0 1-11.32-11.32L148.69 136H88a8 8 0 0 1 0-16h60.69l-18.35-18.34a8 8 0 0 1 11.32-11.32l32 32a8 8 0 0 1 0 11.32Z"/></svg>
        </a>
      </div>
    </div>
  </div>
</div>

<footer
  class="relative z-10 py-12 border-t border-white/10 bg-deep-blue/80 backdrop-blur-md"
>
  <div class="w-full px-6 md:px-12 lg:px-20">
    <div class="max-w-7xl mx-auto flex flex-col md:flex-row justify-between items-center gap-6">

      <!-- Brand -->
      <div class="flex items-center gap-3">
        <img
          src="/assets/logo/logo.jpeg"
          alt="ALFA-PADEL Burgau Logo"
          class="w-10 h-10 rounded-lg object-cover"
          width="40"
          height="40"
          loading="lazy"
        />
        <span class="font-black uppercase tracking-tighter text-white text-lg">
          ALFA-<span class="text-electric-lime">PADEL</span> <span class="text-cyan-accent">Burgau</span>
        </span>
      </div>

      <!-- Links -->
      <nav aria-label="Footer Navigation">
        <ul class="flex flex-wrap justify-center gap-6 text-sm text-slate-400">
          <li>
              <a href="/datenschutz" id="datenschutz" class="hover:text-electric-lime transition-colors focus:outline-none focus:ring-2 focus:ring-electric-lime rounded px-1">
                Datenschutz / Privacy
              </a>
          </li>
          <li>
            <a href="/impressum" class="hover:text-electric-lime transition-colors focus:outline-none focus:ring-2 focus:ring-electric-lime rounded px-1">
              Impressum / Legal
            </a>
          </li>
          <li>
            <a href="#" class="hover:text-electric-lime transition-colors focus:outline-none focus:ring-2 focus:ring-electric-lime rounded px-1">
              Kontakt / Contact
            </a>
          </li>
          <li>
            <button
              type="button"
              onclick="window.dispatchEvent(new CustomEvent('open-cookie-settings'))"
              class="hover:text-electric-lime transition-colors focus:outline-none focus:ring-2 focus:ring-electric-lime rounded px-1 cursor-pointer bg-transparent border-none"
            >
              Cookie-Einstellungen / Cookie Settings
            </button>
          </li>
        </ul>
      </nav>

      <!-- Copyright -->
      <p class="text-xs text-slate-500 font-mono">
        &copy; {currentYear} ALFA-PADEL Burgau
      </p>
    </div>
  </div>
</footer>

