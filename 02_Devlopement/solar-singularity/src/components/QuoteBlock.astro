---
export interface Props {
  quote: string;
  author: string;
  class?: string;
}

const { quote, author, class: className = '' } = Astro.props;
---

<figure
  class={`max-w-3xl mx-auto text-center p-8 md:p-12 ${className}`}
  aria-labelledby="quote-text"
>
  <blockquote>
    <svg
      class="w-10 h-10 text-electric-lime/40 mx-auto mb-6"
      viewBox="0 0 24 24"
      fill="currentColor"
      aria-hidden="true"
    >
      <path d="M4.583 17.321C3.553 16.227 3 15 3 13.011c0-3.5 2.457-6.637 6.03-8.188l.893 1.378c-3.335 1.804-3.987 4.145-4.247 5.621.537-.278 1.24-.375 1.929-.311 1.804.167 3.226 1.648 3.226 3.489a3.5 3.5 0 0 1-3.5 3.5c-1.073 0-2.099-.49-2.748-1.179zm10 0C13.553 16.227 13 15 13 13.011c0-3.5 2.457-6.637 6.03-8.188l.893 1.378c-3.335 1.804-3.987 4.145-4.247 5.621.537-.278 1.24-.375 1.929-.311 1.804.167 3.226 1.648 3.226 3.489a3.5 3.5 0 0 1-3.5 3.5c-1.073 0-2.099-.49-2.748-1.179z"/>
    </svg>

    <p
      id="quote-text"
      class="text-2xl md:text-4xl font-light text-white leading-snug italic"
    >
      &ldquo;{quote}&rdquo;
    </p>
  </blockquote>

  <figcaption class="mt-8">
    <div class="w-16 h-0.5 bg-electric-lime/50 mx-auto mb-4"></div>
    <cite class="not-italic text-cyan-accent font-medium tracking-wide uppercase text-sm">
      {author}
    </cite>
  </figcaption>
</figure>
