---
import type { Sponsor } from '../data/sponsors';

interface Props {
  sponsor: Sponsor;
  index?: number;
  variant?: 'full' | 'compact' | 'inline';
}

const { sponsor, index = 0, variant = 'full' } = Astro.props;

const tierStyles: Record<string, { badge: string; border: string; glow: string; dot: string }> = {
  gold: {
    badge: 'bg-electric-lime/15 text-electric-lime border-electric-lime/30',
    border: 'border-electric-lime/20 hover:border-electric-lime/40',
    glow: 'hover:shadow-[0_0_50px_rgba(206,255,5,0.12)]',
    dot: 'bg-electric-lime',
  },
  silver: {
    badge: 'bg-cyan-accent/15 text-cyan-accent border-cyan-accent/30',
    border: 'border-cyan-accent/20 hover:border-cyan-accent/40',
    glow: 'hover:shadow-[0_0_50px_rgba(0,212,255,0.12)]',
    dot: 'bg-cyan-accent',
  },
  bronze: {
    badge: 'bg-white/10 text-slate-300 border-white/15',
    border: 'border-white/10 hover:border-white/30',
    glow: 'hover:shadow-[0_0_40px_rgba(255,255,255,0.06)]',
    dot: 'bg-slate-400',
  },
};

const tierLabels: Record<string, { de: string; en: string }> = {
  gold: { de: 'Grand Slam Burgau', en: 'Grand Slam Burgau' },
  silver: { de: 'Thermen-Partner', en: 'Thermal Partner' },
  bronze: { de: 'Local Hero', en: 'Local Hero' },
};

const s = tierStyles[sponsor.tier];
const t = tierLabels[sponsor.tier];

const delay = Math.min(index * 80, 600);
---

{
  variant === 'full' && (
    <a
      href={sponsor.url}
      target={sponsor.url.startsWith('http') ? '_blank' : '_self'}
      rel={sponsor.url.startsWith('http') ? 'noopener noreferrer' : undefined}
      class={`group block p-6 md:p-8 bg-white/5 backdrop-blur-md border rounded-2xl transition-all duration-500 hover:-translate-y-1 reveal ${s.border} ${s.glow}`}
      style={`transition-delay: ${delay}ms`}
      aria-label={`${sponsor.name} – ${t.de}`}
    >
      <!-- Tier Badge -->
      <div class="flex items-center justify-between mb-5">
        <span class={`inline-flex items-center gap-1.5 px-3 py-1 text-xs font-mono font-bold uppercase tracking-widest rounded-full border ${s.badge}`}>
          <span class={`w-1.5 h-1.5 rounded-full ${s.dot}`} aria-hidden="true"></span>
          {t.de} / {t.en}
        </span>
        <span class={`w-2 h-2 rounded-full ${s.dot} animate-pulse`} aria-hidden="true"></span>
      </div>

      <!-- Logo Placeholder -->
      <div class="w-full h-20 mb-5 rounded-xl bg-gradient-to-br from-white/10 to-white/5 flex items-center justify-center border border-white/10 group-hover:border-white/20 transition-colors duration-500">
        <span class={`text-lg font-black uppercase tracking-tighter ${sponsor.tier === 'gold' ? 'text-electric-lime' : sponsor.tier === 'silver' ? 'text-cyan-accent' : 'text-slate-400'}`}>
          {sponsor.name}
        </span>
      </div>

      <!-- Name + Location -->
      <h3 class="text-xl font-black text-white mb-1 leading-tight">
        {sponsor.name}
      </h3>
      <p class="text-xs text-slate-500 font-mono uppercase tracking-wider mb-4">
        {sponsor.location}
      </p>

      <!-- Description DE -->
      <p class="text-sm text-slate-400 leading-relaxed mb-3">
        {sponsor.description}
      </p>

      <!-- Description EN -->
      <p class="text-xs text-slate-500 leading-relaxed italic">
        {sponsor.descriptionEn}
      </p>

      <!-- Hover Arrow -->
      <div class="mt-5 flex items-center gap-2 text-xs font-mono uppercase tracking-widest text-slate-500 group-hover:text-electric-lime transition-colors duration-300">
        <span>Mehr erfahren</span>
        <svg class="w-3.5 h-3.5 transform group-hover:translate-x-1 transition-transform duration-300" viewBox="0 0 256 256" fill="currentColor" aria-hidden="true">
          <path d="m221.66 133.66-72 72a8 8 0 0 1-11.32-11.32L196.69 136H40a8 8 0 0 1 0-16h156.69l-58.35-58.34a8 8 0 0 1 11.32-11.32l72 72a8 8 0 0 1 0 11.32Z"/>
        </svg>
      </div>
    </a>
  )
}

{
  variant === 'compact' && (
    <a
      href={sponsor.url}
      target={sponsor.url.startsWith('http') ? '_blank' : '_self'}
      rel={sponsor.url.startsWith('http') ? 'noopener noreferrer' : undefined}
      class={`group flex items-center gap-4 p-4 bg-white/5 backdrop-blur-md border rounded-xl transition-all duration-300 hover:bg-white/10 hover:-translate-y-0.5 reveal ${s.border}`}
      style={`transition-delay: ${delay}ms`}
      aria-label={`${sponsor.name} – ${t.de}`}
    >
      <div class="w-10 h-10 rounded-lg bg-gradient-to-br from-white/10 to-white/5 flex items-center justify-center border border-white/10 flex-shrink-0">
        <span class={`text-xs font-black uppercase ${sponsor.tier === 'gold' ? 'text-electric-lime' : sponsor.tier === 'silver' ? 'text-cyan-accent' : 'text-slate-400'}`}>
          {sponsor.name.charAt(0)}
        </span>
      </div>
      <div class="flex-1 min-w-0">
        <div class="text-sm font-bold text-white truncate">{sponsor.name}</div>
        <div class="text-xs text-slate-500">{sponsor.location}</div>
      </div>
      <span class={`w-1.5 h-1.5 rounded-full ${s.dot} flex-shrink-0`} aria-hidden="true"></span>
    </a>
  )
}

{
  variant === 'inline' && (
    <a
      href={sponsor.url}
      target={sponsor.url.startsWith('http') ? '_blank' : '_self'}
      rel={sponsor.url.startsWith('http') ? 'noopener noreferrer' : undefined}
      class="inline-flex items-center gap-1.5 px-3 py-1.5 bg-white/5 backdrop-blur-sm border border-white/10 rounded-full text-xs text-slate-400 hover:text-white hover:border-white/30 hover:bg-white/10 transition-all duration-300"
      aria-label={sponsor.name}
    >
      <span class={`w-1.5 h-1.5 rounded-full ${s.dot}`} aria-hidden="true"></span>
      {sponsor.name}
    </a>
  )
}