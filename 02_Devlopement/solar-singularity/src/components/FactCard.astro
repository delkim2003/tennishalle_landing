---
export interface Props {
  year: string;
  label: string;
  headline: string;
  description: string;
  accentColor?: 'lime' | 'cyan' | 'orange';
  align?: 'left' | 'right';
  ariaLabel?: string;
}

const {
  year,
  label,
  headline,
  description,
  accentColor = 'lime',
  align = 'left',
  ariaLabel
} = Astro.props;

const colorMap = {
  lime: 'border-electric-lime/40',
  cyan: 'border-cyan-accent/40',
  orange: 'border-orange-400/40',
};

const bgGlowMap = {
  lime: 'hover:shadow-electric-lime/10',
  cyan: 'hover:shadow-cyan-accent/10',
  orange: 'hover:shadow-orange-400/10',
};
---

<div
  class={`max-w-lg w-full p-6 md:p-8 bg-white/10 backdrop-blur-xl border-l-4 ${colorMap[accentColor]} rounded-r-2xl shadow-2xl ${bgGlowMap[accentColor]} hover:shadow-2xl transition-all duration-500 hover:scale-[1.02] ${align === 'right' ? 'ml-auto' : 'mr-auto'}`}
  aria-label={ariaLabel}
>
  <div class="flex items-center gap-3 mb-3">
    <span class="px-3 py-1 text-xs font-mono font-bold uppercase tracking-widest bg-electric-lime/10 text-electric-lime rounded-full border border-electric-lime/20">
      {label}
    </span>
    <span class="text-sm font-mono text-cyan-accent">{year}</span>
  </div>

  <h3 class="text-xl md:text-2xl font-bold text-white mb-2 leading-tight">
    {headline}
  </h3>

  <p class="text-slate-300 text-sm md:text-base leading-relaxed">
    {description}
  </p>
</div>
