---
import '../styles/global.css';
import CookieBanner from '../components/CookieBanner.astro';
import LanguageSwitcher from '../components/LanguageSwitcher.astro';

export interface Props {
  title: string;
  description?: string;
  lang?: string;
}

const {
  title,
  description = "ALFA-PADEL Burgau – Erlebe Padel auf höchstem Niveau in unserer modernen Indoor-Anlage in der Thermen- und Vulkanlandregion. Smart Booking, Premium Courts, perfekte Bedingungen – ganzjährig.",
  lang = "de"
} = Astro.props;
---

<!DOCTYPE html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="robots" content="noindex, nofollow" />
    <meta name="theme-color" content="#0A192F" />
    <meta name="color-scheme" content="dark" />
    <link rel="icon" type="image/jpeg" href="/assets/logo/logo.jpeg" />
    <link rel="preload" as="fetch" href="/assets/videos/tennis-court-flythrough.mp4" crossorigin="anonymous" />
    <title>{title.slice(0, 70)}</title>
    <script type="application/ld+json" is:inline>
      {
        "@context": "https://schema.org",
        "@type": "SportsActivityLocation",
        "name": "ALFA-PADEL Burgau",
        "description": ${JSON.stringify(description)},
        "url": "https://alfa-padel-burgau.at",
        "logo": "https://alfa-padel-burgau.at/assets/logo/logo.jpeg",
        "image": "https://alfa-padel-burgau.at/assets/logo/logo.jpeg",
        "address": {
          "@type": "PostalAddress",
          "addressLocality": "Burgau",
          "addressCountry": "AT"
        },
        "openingHoursSpecification": {
          "@type": "OpeningHoursSpecification",
          "dayOfWeek": ["Monday","Tuesday","Wednesday","Thursday","Friday","Saturday","Sunday"],
          "opens": "07:00",
          "closes": "22:00"
        },
        "priceRange": "€€",
        "currenciesAccepted": "EUR",
        "paymentAccepted": "Cash, Credit Card, Debit Card"
      }
    </script>
  </head>
  <body class="bg-deep-blue text-white antialiased overflow-x-hidden">
    <!-- Skip-Link für WCAG 2.4.1 -->
    <a href="#main-content" class="sr-only focus:not-sr-only focus:absolute focus:top-4 focus:left-4 focus:z-[9999] focus:px-4 focus:py-2 focus:bg-electric-lime focus:text-deep-blue focus:rounded-lg focus:font-bold focus:text-sm focus:outline-none focus:ring-2 focus:ring-white">
      Zum Hauptinhalt springen / Skip to main content
    </a>

    <!-- Language Switcher -->
    <div class="fixed top-4 right-4 z-[9998]">
      <LanguageSwitcher />
    </div>

    <!-- Scroll Progress Bar (non-focusable, aria-hidden is correct) -->
    <div class="scroll-progress" id="scroll-progress" aria-hidden="true" inert></div>
    <div id="main-content" class="contents">
      <slot />
    </div>

    <!-- Cookie Consent Banner -->
    <CookieBanner />

    <!-- 1. Cookie-Banner – Pure Vanilla JS (kein Alpine, keine js-cookie) -->
    <script src="/js/cookie-banner.js" defer></script>
    <!-- 2. Alpine.js Core – setzt window.Alpine -->
    <script src="/js/alpine.min.js" defer></script>
    <!-- 3. Alpine.js Init – registriert Language Store und ruft Alpine.start() auf -->
    <script src="/js/alpine-init.js" defer></script>
    <!-- 4. Scroll-Reveal (& Scroll-Progress) – hängt von Alpine ab -->
    <script src="/js/scroll-reveal.js" defer></script>
    <!-- 5. Video Scrub – hängt von keinem Framework ab -->
    <script src="/js/video-scrub.js" defer></script>
  </body>
</html>